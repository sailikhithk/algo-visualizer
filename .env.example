# AlgoViz environment — copy to .env and fill in the keys you want to use.
#
# Provider auto-selection (server/ai-config.ts → detectProvider):
#   1. DEEPSEEK_API_KEY   → use DeepSeek (V4 Flash/Pro - cheapest, 5M free tokens)
#   2. OPENROUTER_API_KEY → use OpenRouter (free models: Gemma, Llama, Phi-3, Qwen)
#   3. GROQ_API_KEY      → use Groq (Llama / GPT-OSS / Kimi via OpenAI-compat API)
#   4. ANTHROPIC_API_KEY → use Anthropic (Claude)
#   5. neither           → /api/* will 500 with a clear error
#
# Set ONLY the one you want. If multiple are set, DeepSeek wins (cheapest).

# DeepSeek — get a key at https://platform.deepseek.com/ (format: sk-...)
# 5M free tokens, $0.14 input / $0.28 output per million tokens (V4 Flash)
DEEPSEEK_API_KEY=

# OpenRouter — get a key at https://openrouter.ai/keys (format: sk-or-...)
# Free models available: https://openrouter.ai/models?free=true
OPENROUTER_API_KEY=

# Groq — get a key at https://console.groq.com/keys (format: gsk_...)
GROQ_API_KEY=

# Anthropic — get a key at https://console.anthropic.com/settings/keys (format: sk-ant-...)
ANTHROPIC_API_KEY=

# Server
PORT=3002
NODE_ENV=development
